{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",

  "tabWidth": 2,
  "singleQuote": false,
  "semi": true,
  "trailingComma": "all",
  "quoteProps": "consistent",

  "ignorePatterns": [
    "**/CHANGELOG.md",
    "**/pnpm*.yaml",
    "**/dist/**",
    "**/*.gen.ts",
    "**/.cache/**",
    "**/node_modules/**",
    "**/coverage/**"
  ]
}
