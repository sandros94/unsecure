{
  "name": "unsecure",
  "version": "0.2.2",
  "description": "Low-level Security utilities",
  "license": "MIT",
  "author": {
    "name": "Sandro Circi",
    "email": "sandro.circi@digitoolmedia.com"
  },
  "repository": "sandros94/unsecure",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./compare": {
      "types": "./dist/compare.d.mts",
      "default": "./dist/compare.mjs"
    },
    "./entropy": {
      "types": "./dist/entropy.d.mts",
      "default": "./dist/entropy.mjs"
    },
    "./generate": {
      "types": "./dist/generate.d.mts",
      "default": "./dist/generate.mjs"
    },
    "./hash": {
      "types": "./dist/hash.d.mts",
      "default": "./dist/hash.mjs"
    },
    "./hkdf": {
      "types": "./dist/hkdf.d.mts",
      "default": "./dist/hkdf.mjs"
    },
    "./hmac": {
      "types": "./dist/hmac.d.mts",
      "default": "./dist/hmac.mjs"
    },
    "./otp": {
      "types": "./dist/otp.d.mts",
      "default": "./dist/otp.mjs"
    },
    "./random": {
      "types": "./dist/random.d.mts",
      "default": "./dist/random.mjs"
    },
    "./sanitize": {
      "types": "./dist/sanitize.d.mts",
      "default": "./dist/sanitize.mjs"
    },
    "./uuid": {
      "types": "./dist/uuid.d.mts",
      "default": "./dist/uuid.mjs"
    },
    "./utils": {
      "types": "./dist/utils/index.d.mts",
      "default": "./dist/utils/index.mjs"
    }
  },
  "scripts": {
    "build": "obuild",
    "stub": "obuild --stub",
    "dev:prepare": "obuild --stub && pnpm simple-git-hooks",
    "lint": "oxlint . && oxfmt --check .",
    "fmt": "oxlint --fix . && oxfmt .",
    "prepack": "pnpm build",
    "test": "vitest run --slowTestThreshold=1000",
    "test:coverage": "vitest run --coverage --slowTestThreshold=1000",
    "typecheck": "tsgo --noEmit",
    "bench": "vitest bench --run"
  },
  "devDependencies": {
    "@types/node": "^24",
    "@typescript/native-preview": "7.0.0-dev.20260419.1",
    "@vitest/coverage-v8": "^4.1.10",
    "obuild": "^0.4.38",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "oxlint-tsgolint": "^0.24.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "resolutions": {
    "unsecure": "link:."
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm stub && pnpm lint && pnpm typecheck"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.13.0",
      "onFail": "download"
    },
    "runtime": {
      "name": "node",
      "version": ">=24.11.0",
      "onFail": "error"
    }
  },
  "packageManager": "pnpm@11.13.0"
}
